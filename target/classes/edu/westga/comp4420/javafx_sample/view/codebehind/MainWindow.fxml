<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane minHeight="99.0" minWidth="160.0" prefHeight="380.0" prefWidth="474.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.westga.comp4420.javafx_sample.view.codebehind.MainWindow">
    <children>
        <VBox spacing="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="10">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <children>
                <Label text="Shopping List" />
                <HBox spacing="10">
                    <children>
                        <TextField fx:id="itemNameField" promptText="Item Name" />
                        <TextField fx:id="quantityField" promptText="Quantity" />
                    </children>
                </HBox>
                <ListView fx:id="itemListView" prefHeight="200" />
            </children>
        </VBox>
        <Button fx:id="addButton" layoutX="21.0" layoutY="308.0" onAction="#handleAdd" text="Add" />
        <Button fx:id="removeButton" layoutX="90.0" layoutY="308.0" onAction="#handleRemove" text="Remove" />
        <Button fx:id="updateButton" layoutX="170.0" layoutY="308.0" onAction="#handleUpdate" text="Update" />
    </children>
</AnchorPane>